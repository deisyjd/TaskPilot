# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://taskpilot:password@localhost:5432/taskpilot"

# JWT — use a long random string in production
JWT_SECRET="replace-with-a-secure-random-secret"

# Contraseña temporal para los usuarios creados por el seed inicial de
# producción (solo se usa la primera vez, si la base de datos no tiene
# usuarios todavía). Usa un valor fuerte y único por despliegue — nunca
# el mismo que en prisma/seed.ts (ese es solo para desarrollo local).
# Cambien la contraseña desde el panel apenas puedan entrar.
SEED_USER_PASSWORD="replace-with-a-strong-temporary-password"

# Next.js
NODE_ENV="production"

# SMTP — resumen diario por correo (lun-vie 7am hora Colombia)
SMTP_HOST="mail.tudominio.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="notificaciones@tudominio.com"
SMTP_PASSWORD="replace-with-smtp-password"
SMTP_FROM="Wipli <notificaciones@tudominio.com>"

# URL pública de la app, usada en el botón "Abrir Wipli" del correo
APP_URL="https://wipli.adminainoa.com"

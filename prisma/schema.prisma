generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  color     String   @default("#8B5CF6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       CompanyMembership[]
  projects          Project[]
  tasks             Task[]
  historyEvents     HistoryEvent[]
  notes             Note[]
  conversations     Conversation[]
  lastActiveForUser User[]              @relation("UserLastActiveCompany")

  @@map("companies")
}

model CompanyMembership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String   @default("member")
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("company_memberships")
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  role                String
  userRole            String   @default("member")
  initials            String
  color               String   @default("bg-violet-500")
  avatarUrl           String?  @db.Text
  status              String   @default("active")
  lastActiveCompanyId String?
  lastActiveCompany   Company? @relation("UserLastActiveCompany", fields: [lastActiveCompanyId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships              CompanyMembership[]
  projectMemberships       ProjectMember[]
  taskAssignments          TaskAssignee[]
  messages                 Message[]
  conversationParticipants ConversationParticipant[]
  createdProjects          Project[]                  @relation("ProjectCreator")
  taggedChecklistItems     ChecklistItem[]

  @@map("users")
}

model Project {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  description   String?  @db.Text
  color         String   @default("#8B5CF6")
  status        String   @default("active")
  featured      Boolean  @default(false)
  coverImageUrl String?  @db.Text
  createdById   String?
  createdBy     User?    @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks   Task[]
  notes   Note[]
  members ProjectMember[]

  @@unique([companyId, name])
  @@map("projects")
}

model Task {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  status      String   @default("pending")
  dueDate     String
  priority    String   @default("medium")
  type        String   @default("other")
  tags        Json     @default("[]")
  coverImageUrl String? @db.Text
  attachments Json?
  links       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Recurrencia: la tarea original (parentTaskId = null, recurrence definido)
  // es la plantilla; cada ocurrencia generada apunta a ella.
  recurrence         String?
  recurrenceInterval Int?
  recurrenceUntil    String?
  parentTaskId       String?
  parentTask         Task?   @relation("TaskRecurrence", fields: [parentTaskId], references: [id], onDelete: SetNull)
  occurrences        Task[]  @relation("TaskRecurrence")

  checklist ChecklistItem[]
  comments  Comment[]
  assignees TaskAssignee[]

  @@index([companyId])
  @@index([projectId])
  @@index([parentTaskId])
  @@map("tasks")
}

model TaskAssignee {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
  @@map("task_assignees")
}

model ChecklistItem {
  id         String  @id @default(cuid())
  taskId     String
  task       Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text       String
  done       Boolean @default(false)
  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@map("checklist_items")
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    String
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@map("comments")
}

model HistoryEvent {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String
  taskId      String?
  taskTitle   String?
  project     String?
  description String   @db.Text
  user        String
  timestamp   DateTime @default(now())
  meta        Json?

  @@index([companyId])
  @@map("history_events")
}

model Conversation {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String?
  type          String   @default("direct")
  coverImageUrl String?  @db.Text
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([companyId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  attachments    Json?
  links          Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

model Note {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String?  @db.Text
  color     String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([projectId])
  @@map("notes")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  color     String   @default("#8B5CF6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       CompanyMembership[]
  projects          Project[]
  tasks             Task[]
  historyEvents     HistoryEvent[]
  lastActiveForUser User[]              @relation("UserLastActiveCompany")

  @@map("companies")
}

model CompanyMembership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String   @default("member")
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("company_memberships")
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  role                String
  userRole            String   @default("member")
  initials            String
  color               String   @default("bg-violet-500")
  avatarUrl           String?  @db.Text
  status              String   @default("active")
  lastActiveCompanyId String?
  lastActiveCompany   Company? @relation("UserLastActiveCompany", fields: [lastActiveCompanyId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships CompanyMembership[]

  @@map("users")
}

model Project {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  description   String?  @db.Text
  color         String   @default("#8B5CF6")
  status        String   @default("active")
  featured      Boolean  @default(false)
  coverImageUrl String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks Task[]
  notes Note[]

  @@unique([companyId, name])
  @@map("projects")
}

model Task {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  status      String   @default("pending")
  assignee    String
  dueDate     String
  priority    String   @default("medium")
  type        String   @default("other")
  tags        Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklist ChecklistItem[]
  comments  Comment[]

  @@index([companyId])
  @@index([projectId])
  @@map("tasks")
}

model ChecklistItem {
  id     String  @id @default(cuid())
  taskId String
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text   String
  done   Boolean @default(false)

  @@map("checklist_items")
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    String
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@map("comments")
}

model HistoryEvent {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String
  taskId      String?
  taskTitle   String?
  project     String?
  description String   @db.Text
  user        String
  timestamp   DateTime @default(now())
  meta        Json?

  @@index([companyId])
  @@map("history_events")
}

model Conversation {
  id           String   @id @default(cuid())
  name         String?
  type         String   @default("direct")
  participants Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  @@map("messages")
}

model Note {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

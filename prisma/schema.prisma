generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String
  userRole  String   @default("member")
  initials  String
  color     String   @default("bg-violet-500")
  avatarUrl String?  @db.Text
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Project {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?  @db.Text
  color         String   @default("#8B5CF6")
  status        String   @default("active")
  featured      Boolean  @default(false)
  coverImageUrl String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks Task[]
  notes Note[]

  @@map("projects")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  projectName String
  project     Project  @relation(fields: [projectName], references: [name])
  description String?  @db.Text
  status      String   @default("pending")
  assignee    String
  dueDate     String
  priority    String   @default("medium")
  type        String   @default("other")
  tags        Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklist ChecklistItem[]
  comments  Comment[]

  @@map("tasks")
}

model ChecklistItem {
  id     String  @id @default(cuid())
  taskId String
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text   String
  done   Boolean @default(false)

  @@map("checklist_items")
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    String
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@map("comments")
}

model HistoryEvent {
  id          String   @id @default(cuid())
  type        String
  taskId      String?
  taskTitle   String?
  project     String?
  description String   @db.Text
  user        String
  timestamp   DateTime @default(now())
  meta        Json?

  @@map("history_events")
}

model Conversation {
  id           String   @id @default(cuid())
  name         String?
  type         String   @default("direct")
  participants Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  @@map("messages")
}

model Note {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}
